---
import Layout from '../layouts/Layout.astro';

const projects = [
	{ id: "001", name: "Realm", url: "https://realm.byjennyzhu.com", description: "HOROSCOPE APP" },
	{ id: "002", name: "Movement", url: "https://movement.byjennyzhu.com", description: "PHYSICAL PRACTICE" },
];
---

<Layout title="Jenny Zhu">
	<div class="page-wrapper">
		<!-- Scaffolding overlay -->
		<div class="scaffolding">
			<div class="scaffold-line scaffold-v scaffold-v1"></div>
			<div class="scaffold-line scaffold-v scaffold-v2"></div>
			<div class="scaffold-line scaffold-h scaffold-h1"></div>
			<div class="scaffold-line scaffold-h scaffold-h2"></div>
			<div class="crosshair ch-1"></div>
			<div class="crosshair ch-2"></div>
			<div class="crosshair ch-3"></div>
			<div class="crosshair ch-4"></div>
		</div>

		<div class="app-window">
			<!-- Tabs -->
			<div class="tabs-container">
				<button class="tab tab-1 active" data-tab="about" data-ref="/HOME/JENNY_ZHU">About</button>
				<button class="tab tab-2" data-tab="cv" data-ref="/HOME/JENNY_ZHU/CV">CV</button>
				<button class="tab tab-3" data-tab="projects" data-ref="/HOME/JENNY_ZHU/PROJECTS">Projects</button>
			</div>

			<!-- Window body -->
			<div class="app-body">
				<!-- Window header bar -->
				<div class="window-header">
					<span class="ref mono">Ref: /HOME/JENNY_ZHU</span>
					<div class="header-dots">
						<span class="dot dot-outline"></span>
						<span class="dot dot-filled"></span>
					</div>
				</div>

				<!-- Persistent name -->
				<div class="name-block">
					<h1 class="site-name">Jenny Zhu</h1>
				</div>

				<!-- Scrollable content -->
				<div class="content-scroll">

					<!-- ABOUT -->
					<section id="about" class="pane active">
						<div class="about-body">
							<p class="about-text">
								I'm an investor at <a href="https://propel.vc" target="_blank" rel="noopener">Propel Venture Partners</a>, where I focus on pre-seed / seed-stage fintech. My interests span payments, infrastructure, commerce, institutional crypto, mission-driven companies, and more &mdash; the envelope-pushers and the category-definers.
							</p>

							<p class="about-text">
								Previously, I spent five years in investment banking advising companies (e.g., PayPal, Ripple, Franklin Templeton, Xpansiv, FTX Debtors) across M&A, capital raises, and strategic transactions.
							</p>

							<div class="divider"></div>

							<div class="about-footer">
								<p class="location mono">
									Based in San Francisco,<br />
									previously New York City and Dallas.
								</p>
								<div class="links">
									<a href="mailto:hello@byjennyzhu.com" class="mono">Email</a>
									<a href="https://x.com/imjennyzhu" target="_blank" rel="noopener" class="mono">Twitter</a>
								</div>
							</div>
						</div>
					</section>

					<!-- PROJECTS -->
					<section id="projects" class="pane">
						<div class="archive-list">
							{projects.map(project => (
								<div class="archive-row">
									<div class="archive-row-left">
										<span class="entry-label mono">ENTRY. {project.id}</span>
										<h3 class="archive-name">{project.name}</h3>
									</div>
									<span class="coming-soon mono">COMING SOON</span>
								</div>
							))}
						</div>
					</section>

					<!-- CV -->
					<section id="cv" class="pane cv-pane">
						<button class="cv-link" id="cv-open">
							<span class="cv-link-text">View Resume / CV</span>
							<span class="cv-link-arrow">&rarr;</span>
						</button>
					</section>


				</div>

				<!-- Footer -->
				<div class="window-footer">
					<span class="mono footer-right">&copy; 2026 J. Zhu</span>
				</div>
			</div>
		</div>
	</div>
	<!-- PDF Viewer Modal -->
	<div class="pdf-modal" id="pdf-modal">
		<div class="pdf-modal-backdrop"></div>
		<div class="pdf-modal-window">
			<div class="pdf-modal-header">
				<span class="pdf-modal-title mono">Resume — Jenny Zhu</span>
				<div class="pdf-modal-actions">
					<a href="/Jenny-Zhu-Resume.pdf" download class="pdf-modal-btn mono">
						<span>Download</span>
						<span class="pdf-btn-arrow">&darr;</span>
					</a>
					<button class="pdf-modal-close" id="pdf-close" aria-label="Close">&times;</button>
				</div>
			</div>
			<div class="pdf-modal-body" id="pdf-pages"></div>
		</div>
	</div>
</Layout>

<script>
	function switchTab(tabId: string) {
		document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
		document.querySelectorAll('.pane').forEach(p => p.classList.remove('active'));
		const tab = document.querySelector(`.tab[data-tab="${tabId}"]`) as HTMLElement;
		tab.classList.add('active');
		document.getElementById(tabId)!.classList.add('active');
		document.querySelector('.ref')!.textContent = `Ref: ${tab.getAttribute('data-ref')}`;
	}

	document.querySelectorAll('.tab').forEach(tab => {
		tab.addEventListener('click', () => {
			switchTab(tab.getAttribute('data-tab')!);
		});
	});

	const modal = document.getElementById('pdf-modal')!;
	const pagesContainer = document.getElementById('pdf-pages')!;
	let pdfRendered = false;

	document.getElementById('cv-open')!.addEventListener('click', async () => {
		modal.classList.add('open');
		document.body.style.overflow = 'hidden';

		if (!pdfRendered) {
			pdfRendered = true;
			const pdfjsLib = await import('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.9.155/pdf.min.mjs');
			pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.9.155/pdf.worker.min.mjs';

			const pdf = await pdfjsLib.getDocument('/Jenny-Zhu-Resume.pdf').promise;
			for (let i = 1; i <= pdf.numPages; i++) {
				const page = await pdf.getPage(i);
				const scale = 2;
				const viewport = page.getViewport({ scale });
				const canvas = document.createElement('canvas');
				canvas.width = viewport.width;
				canvas.height = viewport.height;
				await page.render({ canvasContext: canvas.getContext('2d')!, viewport }).promise;
				const img = document.createElement('img');
				img.className = 'pdf-page';
				img.src = canvas.toDataURL();
				img.alt = `Resume page ${i}`;
				pagesContainer.appendChild(img);
			}
		}
	});

	function closeModal() {
		modal.classList.remove('open');
		document.body.style.overflow = '';
	}

	document.getElementById('pdf-close')!.addEventListener('click', closeModal);
	document.querySelector('.pdf-modal-backdrop')!.addEventListener('click', closeModal);
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
	});
</script>

<style>
	@font-face {
		font-family: 'Aujournuit';
		src: url('/fonts/Aujournuit-Densed.woff2') format('woff2'),
			 url('/fonts/Aujournuit-Densed.woff') format('woff');
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}

	/* Background */
	.page-wrapper {
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		padding: 3rem 1rem;
		box-sizing: border-box;
		background-image: url('/bg-hills.png');
		background-size: cover;
		background-position: center;
		position: relative;
		overflow: hidden;
	}

	/* Scaffolding overlay */
	.scaffolding {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		pointer-events: none;
		z-index: 0;
	}

	.scaffold-line {
		position: absolute;
		background: rgba(255, 255, 255, 0.07);
	}

	.scaffold-v {
		width: 1px;
		height: 100%;
		top: 0;
	}

	.scaffold-v1 { left: 12%; }
	.scaffold-v2 { right: 12%; }

	.scaffold-h {
		height: 1px;
		width: 100%;
		left: 0;
	}

	.scaffold-h1 { top: 10%; }
	.scaffold-h2 { bottom: 8%; }

	.crosshair {
		position: absolute;
		width: 11px;
		height: 11px;
	}

	.crosshair::before,
	.crosshair::after {
		content: '';
		position: absolute;
		background: rgba(255, 255, 255, 0.15);
	}

	.crosshair::before {
		width: 100%;
		height: 1px;
		top: 50%;
		transform: translateY(-50%);
	}

	.crosshair::after {
		height: 100%;
		width: 1px;
		left: 50%;
		transform: translateX(-50%);
	}

	.ch-1 { top: 10%; left: 12%; transform: translate(-50%, -50%); }
	.ch-2 { top: 10%; right: 12%; transform: translate(50%, -50%); }
	.ch-3 { bottom: 8%; left: 12%; transform: translate(-50%, 50%); }
	.ch-4 { bottom: 8%; right: 12%; transform: translate(50%, 50%); }

	/* Name block inside window */
	.name-block {
		padding: 1.75rem 2.5rem 0.75rem;
		flex-shrink: 0;
	}

	.site-name {
		font-family: 'Aujournuit', 'Times New Roman', serif;
		font-style: normal;
		font-size: 2.75rem;
		font-weight: 400;
		letter-spacing: -0.01em;
		color: #333;
		margin: 0;
		line-height: 1.1;
	}

	/* App window */
	.app-window {
		width: 90vw;
		max-width: 860px;
		height: 62vh;
		display: flex;
		flex-direction: column;
		position: relative;
		z-index: 1;
		filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.15));
	}

	/* Tabs */
	.tabs-container {
		display: flex;
		align-items: flex-end;
		padding-left: 20px;
		height: 40px;
		position: relative;
		z-index: 10;
	}

	.tab {
		padding: 10px 35px 8px;
		font-family: 'IBM Plex Mono', monospace;
		font-size: 9px;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #555;
		border: none;
		cursor: pointer;
		margin-right: -12px;
		position: relative;
		min-width: 140px;
		text-align: center;
		transition: all 0.2s ease;
		clip-path: polygon(10% 0, 90% 0, 100% 100%, 0% 100%);
	}

	.tab-1 { background: #EAEAE6; z-index: 3; }
	.tab-2 { background: #CED7DE; z-index: 2; }
	.tab-3 { background: #94A3B0; z-index: 1; }

	.tab.active {
		background: #EAEAE6 !important;
		color: #111;
		z-index: 5;
		font-weight: 600;
	}

	.tab:hover:not(.active) {
		opacity: 0.85;
	}

	/* App body */
	.app-body {
		background: #EAEAE6;
		flex: 1;
		border-radius: 4px;
		border-top-left-radius: 0;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	/* Window header */
	.window-header {
		padding: 0.65rem 1.5rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: rgba(0, 0, 0, 0.01);
		flex-shrink: 0;
	}

	.ref {
		font-size: 8px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.2em;
	}

	.header-dots {
		display: flex;
		gap: 6px;
	}

	.dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
	}

	.dot-outline {
		border: 1px solid rgba(0, 0, 0, 0.1);
	}

	.dot-filled {
		background: rgba(0, 0, 0, 0.05);
	}

	/* Scrollable content */
	.content-scroll {
		flex: 1;
		overflow-y: auto;
		min-height: 0;
	}

	.content-scroll::-webkit-scrollbar { width: 4px; }
	.content-scroll::-webkit-scrollbar-thumb { background: #CCC; }

	/* Panes */
	.pane {
		display: none;
		padding: 2rem 2.5rem;
	}

	.pane.active {
		display: block;
	}

	/* Typography */
	.mono {
		font-family: 'IBM Plex Mono', monospace;
	}

	/* About */
	.about-body {
		max-width: 540px;
	}

	.about-text {
		font-size: 13px;
		line-height: 1.7;
		color: rgba(51, 51, 51, 0.9);
		font-weight: 400;
		margin-bottom: 1.25rem;
	}

	.about-text a {
		border-bottom: 1px solid #333;
		transition: opacity 0.2s ease;
	}

	.about-text a:hover {
		opacity: 0.5;
	}

	.divider {
		height: 1px;
		background: #000;
		opacity: 0.05;
		margin: 1.5rem 0;
	}

	.about-footer {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 2rem;
	}

	.location {
		flex: 1;
		font-size: 9px;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: #666;
		line-height: 1.8;
		margin: 0;
	}

	.links {
		display: flex;
		flex-direction: column;
		gap: 6px;
		justify-content: flex-end;
	}

	.links a {
		font-size: 9px;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-weight: 500;
		color: #333;
		transition: opacity 0.2s ease;
	}

	.links a:hover {
		opacity: 0.5;
	}

	/* Projects / Archive */
	.archive-list {
		border-top: 1px solid rgba(0, 0, 0, 0.05);
	}

	.archive-row {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		padding: 1.25rem 0;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		transition: background 0.15s ease;
	}

	.coming-soon {
		font-size: 8px;
		letter-spacing: 0.15em;
		color: rgba(0, 0, 0, 0.3);
	}

	.entry-label {
		font-size: 8px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-bottom: 0.5rem;
		display: block;
	}

	.archive-name {
		font-family: 'Aujournuit', 'Times New Roman', serif;
		font-size: 1.1rem;
		font-weight: 400;
		font-style: normal;
		color: #333;
		margin: 0;
	}

	.archive-detail {
		font-size: 8px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		padding-bottom: 0.25rem;
	}

	/* CV */
	.cv-pane {
		display: none;
		align-items: center;
		justify-content: center;
		height: 100%;
	}

	.cv-pane.active {
		display: flex;
	}

	.cv-link {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem 2rem;
		background: none;
		border: 1px solid rgba(0, 0, 0, 0.1);
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.cv-link:hover {
		background: rgba(0, 0, 0, 0.03);
		border-color: rgba(0, 0, 0, 0.2);
	}

	.cv-link-text {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: #333;
	}

	.cv-link-arrow {
		font-size: 1rem;
		color: #333;
		opacity: 0.4;
		transition: opacity 0.2s ease;
	}

	.cv-link:hover .cv-link-arrow {
		opacity: 1;
	}

	/* PDF Modal */
	.pdf-modal {
		position: fixed;
		inset: 0;
		z-index: 1000;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s ease;
	}

	.pdf-modal.open {
		opacity: 1;
		pointer-events: all;
	}

	.pdf-modal-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.45);
		backdrop-filter: blur(4px);
	}

	.pdf-modal-window {
		position: relative;
		width: 90vw;
		max-width: 720px;
		height: 88vh;
		background: #EAEAE6;
		border-radius: 4px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.3));
		transform: translateY(12px);
		transition: transform 0.25s ease;
	}

	.pdf-modal.open .pdf-modal-window {
		transform: translateY(0);
	}

	.pdf-modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.65rem 1.25rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.06);
		background: rgba(0, 0, 0, 0.01);
		flex-shrink: 0;
	}

	.pdf-modal-title {
		font-size: 8px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.2em;
	}

	.pdf-modal-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.pdf-modal-btn {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 8px;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: #333;
		padding: 0.3rem 0.65rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		transition: all 0.2s ease;
	}

	.pdf-modal-btn:hover {
		background: rgba(0, 0, 0, 0.03);
		border-color: rgba(0, 0, 0, 0.2);
	}

	.pdf-btn-arrow {
		opacity: 0.4;
		transition: opacity 0.2s ease;
	}

	.pdf-modal-btn:hover .pdf-btn-arrow {
		opacity: 1;
	}

	.pdf-modal-close {
		background: none;
		border: 1px solid rgba(0, 0, 0, 0.1);
		font-size: 1.1rem;
		color: #555;
		cursor: pointer;
		width: 26px;
		height: 26px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s ease;
		line-height: 1;
	}

	.pdf-modal-close:hover {
		background: rgba(0, 0, 0, 0.03);
		border-color: rgba(0, 0, 0, 0.2);
		color: #333;
	}

	.pdf-modal-body {
		flex: 1;
		overflow-y: auto;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 1rem;
		background: rgba(0, 0, 0, 0.02);
	}

	.pdf-modal-body::-webkit-scrollbar { width: 4px; }
	.pdf-modal-body::-webkit-scrollbar-thumb { background: #CCC; }

	.pdf-page {
		display: block;
		width: 100%;
		height: auto;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
		border-radius: 2px;
	}

	/* Footer */
	.window-footer {
		padding: 0.65rem 1.5rem;
		border-top: 1px solid rgba(0, 0, 0, 0.05);
		background: rgba(0, 0, 0, 0.02);
		display: flex;
		justify-content: flex-end;
		align-items: center;
		flex-shrink: 0;
	}

	.footer-left {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.status-dot {
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: rgba(102, 102, 102, 0.3);
	}

	.window-footer .mono {
		font-size: 8px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.3em;
	}

	.footer-right {
		opacity: 0.5;
	}

	/* Mobile */
	@media (max-width: 768px) {
		.page-wrapper {
			padding: 1.5rem 0.5rem;
		}

		.scaffolding {
			display: none;
		}

		.name-block {
			padding: 1.25rem 1.25rem 0.5rem;
		}

		.site-name {
			font-size: 2rem;
		}

		.app-window {
			width: 100%;
			height: 70vh;
		}

		.tabs-container {
			padding-left: 10px;
		}

		.tab {
			font-size: 8px;
			padding: 8px 20px 6px;
			min-width: 100px;
			margin-right: -8px;
		}

		.pane {
			padding: 1.5rem 1.25rem;
		}

		.about-footer {
			flex-direction: column;
			gap: 1.5rem;
		}

		.archive-row {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.5rem;
		}
	}

	@media (max-width: 400px) {
		.tab {
			font-size: 7px;
			padding: 7px 14px 5px;
			min-width: 80px;
		}

	}
</style>
