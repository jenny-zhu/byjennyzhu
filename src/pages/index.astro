---
import Layout from '../layouts/Layout.astro';

const projects = [
	{ id: "001", name: "Blueprint", url: "https://blueprint.byjennyzhu.com", description: "STRATEGY & RESEARCH" },
	{ id: "002", name: "Movement", url: "https://movement.byjennyzhu.com", description: "PHYSICAL PRACTICE" },
];
---

<Layout title="Jenny Zhu">
	<div class="page-wrapper">
		<canvas id="bg-canvas"></canvas>

		<div class="content-panel">
			<nav class="tabs">
				<button class="tab active" data-tab="about">About</button>
				<button class="tab" data-tab="projects">Projects</button>
				<button class="tab" data-tab="cv">CV</button>
			</nav>

			<div class="panel-body">
				<header>
					<span class="ref mono">REF: JZ-26</span>
				</header>

				<section class="hero">
					<h1>Jenny Zhu</h1>
				</section>

				<!-- ABOUT -->
				<section id="about" class="tab-content active">
					<p class="about-text">
						I'm an investor at <a href="https://propel.vc" target="_blank" rel="noopener">Propel Venture Partners</a>, where I focus on pre-seed / seed-stage fintech. My interests span payments, commerce, mission-driven companies, and anything pushing the envelope + reinventing categories.
					</p>
					<p class="about-text">
						Previously, I spent five years in investment banking advising companies like PayPal, Ripple, Franklin Templeton, Xpansiv, and the FTX Debtors across M&A, capital raises, and strategic transactions.
					</p>
					<p class="about-text">
						Based in San Francisco, previously New York.
					</p>
				</section>

				<!-- PROJECTS -->
				<section id="projects" class="tab-content">
					<div class="table-header">
						<span class="col-no">NO.</span>
						<span class="col-name">PROJECT</span>
						<span class="col-detail">DETAILS</span>
						<span class="col-link"></span>
					</div>
					<hr />
					{projects.map(project => (
						<a href={project.url} class="table-row" target="_blank" rel="noopener">
							<span class="col-no mono">[{project.id}]</span>
							<span class="col-name project-name">{project.name}</span>
							<span class="col-detail mono">{project.description}</span>
							<span class="col-link arrow">&rarr;</span>
						</a>
					))}
					<hr />
				</section>

				<!-- CV -->
				<section id="cv" class="tab-content">
					<div class="cv-section">
						<h2>Experience</h2>
						<div class="entry">
							<div class="entry-header">
								<a href="https://propel.vc" target="_blank" rel="noopener"><strong>Propel Venture Partners</strong></a>
								<span class="date mono">2026 &mdash; Present</span>
							</div>
							<p class="org">Early-stage venture investing</p>
						</div>
						<div class="entry">
							<div class="entry-header">
								<a href="https://www.pwpartners.com" target="_blank" rel="noopener"><strong>Perella Weinberg Partners</strong></a>
								<span class="date mono">2022 &mdash; 2025</span>
							</div>
							<p class="org">Investment Banking &mdash; FinTech Group</p>
							<div class="deal-grid">
								<a class="deal-card" href="https://www.reuters.com/technology/ripple-raise-new-funding-that-would-value-company-about-11-bln-bloomberg-news-2024-10-04/" target="_blank" rel="noopener">
									<span class="deal-name">Ripple</span>
									<span class="deal-desc mono">$500M Capital Raise</span>
								</a>
								<a class="deal-card" href="https://www.ups.com/us/en/about/news/press-releases/ups-acquires-happy-returns.page" target="_blank" rel="noopener">
									<span class="deal-name">PayPal &rarr; UPS</span>
									<span class="deal-desc mono">Happy Returns Divestiture</span>
								</a>
								<a class="deal-card" href="https://www.businesswire.com/news/home/20220104005474/en/Xpansiv-Raises-400-Million-in-Series-C-Funding-Led-by-Blackstone" target="_blank" rel="noopener">
									<span class="deal-name">Xpansiv</span>
									<span class="deal-desc mono">$525M Growth Raise</span>
								</a>
								<a class="deal-card" href="https://restructuring.primeclerk.com/FTX/" target="_blank" rel="noopener">
									<span class="deal-name">FTX</span>
									<span class="deal-desc mono">Chapter 11 Restructuring</span>
								</a>
							</div>
						</div>
						<div class="entry">
							<div class="entry-header">
								<a href="https://www.broadhaven.com" target="_blank" rel="noopener"><strong>Broadhaven Capital Partners</strong></a>
								<span class="date mono">2021 &mdash; 2022</span>
							</div>
							<p class="org">Investment Banking &mdash; FIG & FinTech</p>
						</div>
						<div class="entry">
							<div class="entry-header">
								<a href="https://www.lazard.com" target="_blank" rel="noopener"><strong>Lazard</strong></a>
								<span class="date mono">2020</span>
							</div>
							<p class="org">Investment Banking &mdash; Restructuring</p>
						</div>
					</div>
					<hr />
					<div class="cv-section">
						<h2>Education</h2>
						<div class="entry">
							<div class="entry-header">
								<a href="https://www.columbia.edu" target="_blank" rel="noopener"><strong>Columbia University</strong></a>
								<span class="date mono">2021</span>
							</div>
							<p class="org">B.A. Financial Economics, Concentration in History</p>
						</div>
					</div>
				</section>

				<footer>
					<p class="mono">&copy; 2026</p>
				</footer>
			</div>
		</div>
	</div>
</Layout>

<script>
	// Tab switching
	document.querySelectorAll('.tab').forEach(tab => {
		tab.addEventListener('click', () => {
			document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
			document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
			tab.classList.add('active');
			document.getElementById(tab.getAttribute('data-tab')!)!.classList.add('active');
		});
	});

	// Pixelated dark green background
	const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;

	function drawPixelBg() {
		const dpr = window.devicePixelRatio || 1;
		canvas.width = canvas.offsetWidth * dpr;
		canvas.height = canvas.offsetHeight * dpr;
		ctx.scale(dpr, dpr);

		const w = canvas.offsetWidth;
		const h = canvas.offsetHeight;
		const pixelSize = 6;

		for (let x = 0; x < w; x += pixelSize) {
			for (let y = 0; y < h; y += pixelSize) {
				const variation = Math.random() * 30 - 15;
				const wave = Math.sin(x * 0.008 + y * 0.003) * 12;
				const depth = Math.cos(y * 0.005) * 8;

				const r = Math.max(0, Math.min(255, 26 + variation + wave + depth));
				const g = Math.max(0, Math.min(255, 46 + variation + wave + depth));
				const b = Math.max(0, Math.min(255, 28 + variation * 0.5 + wave * 0.5));

				ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
				ctx.fillRect(x, y, pixelSize, pixelSize);
			}
		}
	}

	drawPixelBg();
	window.addEventListener('resize', drawPixelBg);
</script>

<style>
	.page-wrapper {
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		position: relative;
		padding: 3rem 1rem;
		box-sizing: border-box;
	}

	/* Pixelated green background */
	#bg-canvas {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
	}

	/* Content panel */
	.content-panel {
		position: relative;
		z-index: 1;
		width: min(740px, 92%);
		display: flex;
		flex-direction: column;
	}

	/* File folder tabs */
	.tabs {
		display: flex;
		padding-left: 1.5rem;
		position: relative;
		z-index: 2;
	}

	.tab {
		background: #8a9e8c;
		border: none;
		cursor: pointer;
		font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.75);
		padding: 0.5rem 1.8rem 0.65rem;
		border-radius: 0;
		position: relative;
		top: 0;
		margin-right: -6px;
		margin-bottom: -1px;
		transition: all 0.2s ease;
		clip-path: polygon(10% 0%, 90% 0%, 100% 100%, 0% 100%);
	}

	.tab:nth-child(1) { background: #95a897; }
	.tab:nth-child(2) { background: #8a9e8c; }
	.tab:nth-child(3) { background: #7d9180; }

	.tab:hover {
		color: #fff;
		transform: translateY(-3px);
		z-index: 2;
	}

	.tab:nth-child(1):hover { background: #a3b5a5; }
	.tab:nth-child(2):hover { background: #98ac9a; }
	.tab:nth-child(3):hover { background: #8b9f8e; }

	.tab.active {
		background: #EAEAE6;
		color: #1a1a1a;
		z-index: 3;
		transform: translateY(0);
		font-weight: 600;
	}

	/* Panel body — the "folder" */
	.panel-body {
		background: #EAEAE6;
		padding: 1.75rem 2.5rem 1rem;
		position: relative;
		height: 560px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	header {
		display: flex;
		justify-content: flex-end;
		margin-bottom: 1rem;
		flex-shrink: 0;
	}

	.ref {
		font-size: 0.65rem;
		color: #999;
		letter-spacing: 0.08em;
	}

	h1 {
		font-size: 1.65rem;
		font-weight: 400;
		letter-spacing: -0.01em;
		margin: 0 0 0.5rem 0;
		line-height: 1.1;
	}

	.hero {
		margin-bottom: 1.25rem;
		padding-top: 0.5rem;
		flex-shrink: 0;
	}

	/* Tab content */
	.tab-content {
		display: none;
		flex: 1;
		overflow-y: auto;
		min-height: 0;
	}

	.tab-content.active {
		display: flex;
		flex-direction: column;
	}

	/* About */
	.about-text {
		font-size: 0.9rem;
		line-height: 1.65;
		max-width: 520px;
		color: #333;
		margin-bottom: 0.6rem;
	}

	.about-text a {
		border-bottom: 1px solid #1a1a1a;
		transition: opacity 0.2s ease;
	}

	.about-text a:hover {
		opacity: 0.5;
	}

	/* Projects table */
	.mono {
		font-family: 'IBM Plex Mono', monospace;
	}

	.table-header {
		display: grid;
		grid-template-columns: 60px 1fr 1fr 30px;
		gap: 1rem;
		font-size: 0.7rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #999;
		padding-bottom: 0.75rem;
	}

	hr {
		border: none;
		border-top: 1px solid #c5bfb8;
		margin: 0 -2.5rem;
		padding: 0 2.5rem;
	}

	.table-row {
		display: grid;
		grid-template-columns: 60px 1fr 1fr 30px;
		gap: 1rem;
		align-items: baseline;
		padding: 1.25rem 0;
		border-bottom: 1px solid #c5bfb8;
		transition: opacity 0.2s ease;
	}

	.table-row:hover {
		opacity: 0.6;
	}

	.col-no {
		font-size: 0.85rem;
		color: #888;
	}

	.project-name {
		font-size: 0.95rem;
		font-weight: 500;
		font-style: italic;
	}

	.col-detail {
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		color: #666;
	}

	.arrow {
		font-size: 1rem;
		opacity: 0.3;
		transition: opacity 0.2s ease;
		text-align: right;
	}

	.table-row:hover .arrow {
		opacity: 1;
	}

	/* CV */
	h2 {
		font-size: 0.7rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #999;
		margin-bottom: 1.25rem;
	}

	.cv-section {
		margin-bottom: 2rem;
	}

	.entry {
		margin-bottom: 1.5rem;
	}

	.entry-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
	}

	.entry-header strong {
		font-weight: 500;
		font-size: 0.92rem;
	}

	.org {
		font-size: 0.8rem;
		color: #666;
		margin-top: 0.25rem;
		font-style: italic;
	}

	.date {
		font-size: 0.8rem;
		color: #888;
	}

	.deal-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
		margin-top: 0.75rem;
	}

	.deal-card {
		background: #dfddd9;
		padding: 0.5rem 0.65rem;
		transition: background 0.15s ease;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.deal-card:hover {
		background: #d4d1cc;
	}

	.deal-name {
		font-weight: 500;
		font-size: 0.78rem;
	}

	.deal-desc {
		font-size: 0.6rem;
		letter-spacing: 0.06em;
		color: #888;
	}

	/* Footer */
	footer {
		margin-top: auto;
		padding-top: 0.6rem;
		padding-bottom: 0.25rem;
		border-top: 1px solid #c5bfb8;
		margin-left: -2.5rem;
		margin-right: -2.5rem;
		padding-left: 2.5rem;
		padding-right: 2.5rem;
		flex-shrink: 0;
	}

	footer p {
		font-size: 0.65rem;
		color: #aaa;
		letter-spacing: 0.08em;
	}

	/* Mobile */
	@media (max-width: 768px) {
		.page-wrapper {
			padding: 1.5rem 0.75rem;
			align-items: flex-start;
		}

		.content-panel {
			width: 100%;
		}

		.panel-body {
			padding: 1.5rem 1.25rem 2rem;
			height: 75vh;
		}

		hr {
			margin-left: -1.25rem;
			margin-right: -1.25rem;
			padding-left: 1.25rem;
			padding-right: 1.25rem;
		}

		footer {
			margin-left: -1.25rem;
			margin-right: -1.25rem;
			padding-left: 1.25rem;
			padding-right: 1.25rem;
		}

		.tabs {
			padding-left: 0.75rem;
		}

		.tab {
			font-size: 0.65rem;
			padding: 0.5rem 1.2rem;
		}

		.table-header,
		.table-row {
			grid-template-columns: 50px 1fr 30px;
		}

		.col-detail {
			display: none;
		}

		h1 {
			font-size: 1.35rem;
		}

		.about-text {
			font-size: 0.85rem;
		}

		.deal-grid {
			grid-template-columns: 1fr;
		}

		.entry-header {
			flex-direction: column;
			gap: 0.15rem;
		}

		header {
			margin-bottom: 1rem;
		}

		.hero {
			margin-bottom: 1.5rem;
		}
	}

	@media (max-width: 400px) {
		.tab {
			font-size: 0.6rem;
			padding: 0.45rem 1rem;
			margin-right: -4px;
		}

		.tabs {
			padding-left: 0.5rem;
		}
	}
</style>
