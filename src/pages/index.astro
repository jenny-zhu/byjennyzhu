---
import Layout from '../layouts/Layout.astro';

const projects = [
	{ id: "001", name: "Blueprint", url: "https://blueprint.byjennyzhu.com", description: "STRATEGY & RESEARCH" },
	{ id: "002", name: "Movement", url: "https://movement.byjennyzhu.com", description: "PHYSICAL PRACTICE" },
];
---

<Layout title="Jenny Zhu">
	<div class="page-wrapper">
		<canvas id="bg-canvas"></canvas>

		<div class="content-panel">
			<nav class="tabs">
				<button class="tab active" data-tab="about">About</button>
				<button class="tab" data-tab="projects">Projects</button>
				<button class="tab" data-tab="cv">CV</button>
			</nav>

			<div class="panel-body">
				<header>
					<span class="ref mono">REF: JZ-26</span>
				</header>

				<section class="hero">
					<p class="label">THE WORK & WORLD OF</p>
					<h1>Jenny Zhu</h1>
				</section>

				<!-- ABOUT -->
				<section id="about" class="tab-content active">
					<p class="about-text">
						Investor at <a href="https://propelvc.com" target="_blank" rel="noopener">Propel VC</a>, exploring the intersection of technology and human potential. Previously in banking in New York, now based in San Francisco.
					</p>
					<p class="about-text">
						More details coming soon.
					</p>
				</section>

				<!-- PROJECTS -->
				<section id="projects" class="tab-content">
					<div class="table-header">
						<span class="col-no">NO.</span>
						<span class="col-name">PROJECT</span>
						<span class="col-detail">DETAILS</span>
						<span class="col-link"></span>
					</div>
					<hr />
					{projects.map(project => (
						<a href={project.url} class="table-row" target="_blank" rel="noopener">
							<span class="col-no mono">[{project.id}]</span>
							<span class="col-name project-name">{project.name}</span>
							<span class="col-detail mono">{project.description}</span>
							<span class="col-link arrow">&rarr;</span>
						</a>
					))}
					<hr />
				</section>

				<!-- CV -->
				<section id="cv" class="tab-content">
					<div class="cv-section">
						<h2>Experience</h2>
						<div class="entry">
							<div class="entry-header">
								<strong>Investor</strong>
								<span class="date mono">2026 &mdash; Present</span>
							</div>
							<p class="org">Propel VC</p>
						</div>
					</div>
					<hr />
					<p class="placeholder">More details coming soon.</p>
				</section>

				<footer>
					<p class="mono">&copy; 2026</p>
				</footer>
			</div>
		</div>
	</div>
</Layout>

<script>
	// Tab switching
	document.querySelectorAll('.tab').forEach(tab => {
		tab.addEventListener('click', () => {
			document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
			document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
			tab.classList.add('active');
			document.getElementById(tab.getAttribute('data-tab')!)!.classList.add('active');
		});
	});

	// Pixelated dark green background
	const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;

	function drawPixelBg() {
		const dpr = window.devicePixelRatio || 1;
		canvas.width = canvas.offsetWidth * dpr;
		canvas.height = canvas.offsetHeight * dpr;
		ctx.scale(dpr, dpr);

		const w = canvas.offsetWidth;
		const h = canvas.offsetHeight;
		const pixelSize = 6;

		for (let x = 0; x < w; x += pixelSize) {
			for (let y = 0; y < h; y += pixelSize) {
				const variation = Math.random() * 30 - 15;
				const wave = Math.sin(x * 0.008 + y * 0.003) * 12;
				const depth = Math.cos(y * 0.005) * 8;

				const r = Math.max(0, Math.min(255, 26 + variation + wave + depth));
				const g = Math.max(0, Math.min(255, 46 + variation + wave + depth));
				const b = Math.max(0, Math.min(255, 28 + variation * 0.5 + wave * 0.5));

				ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
				ctx.fillRect(x, y, pixelSize, pixelSize);
			}
		}
	}

	drawPixelBg();
	window.addEventListener('resize', drawPixelBg);
</script>

<style>
	.page-wrapper {
		display: flex;
		min-height: 100vh;
		position: relative;
	}

	/* Pixelated green background */
	#bg-canvas {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
	}

	/* Content panel */
	.content-panel {
		position: relative;
		z-index: 1;
		margin-left: auto;
		width: 65%;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	/* File folder tabs */
	.tabs {
		display: flex;
		gap: 4px;
		padding-left: 2rem;
		position: relative;
		z-index: 2;
	}

	.tab {
		background: #ddd5cb;
		border: none;
		cursor: pointer;
		font-family: 'IBM Plex Sans', sans-serif;
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #888;
		padding: 0.65rem 1.5rem;
		border-radius: 8px 8px 0 0;
		position: relative;
		top: 1px;
		transition: all 0.15s ease;
	}

	.tab:hover {
		color: #1a1a1a;
		background: #e8e2da;
	}

	.tab.active {
		background: #f5f0eb;
		color: #1a1a1a;
		z-index: 3;
	}

	/* Panel body — the "folder" */
	.panel-body {
		background: #f5f0eb;
		flex: 1;
		padding: 2.5rem 3rem 3rem;
		position: relative;
	}

	header {
		display: flex;
		justify-content: flex-end;
		margin-bottom: 3rem;
	}

	.ref {
		font-size: 0.7rem;
		color: #999;
		letter-spacing: 0.08em;
	}

	.label {
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: #888;
		margin-bottom: 0.75rem;
	}

	h1 {
		font-size: 3rem;
		font-weight: 400;
		letter-spacing: -0.02em;
		margin: 0 0 1rem 0;
		line-height: 1.1;
	}

	.hero {
		margin-bottom: 3rem;
	}

	/* Tab content */
	.tab-content {
		display: none;
		flex: 1;
	}

	.tab-content.active {
		display: block;
	}

	/* About */
	.about-text {
		font-size: 1.1rem;
		line-height: 1.7;
		max-width: 520px;
		color: #333;
		margin-bottom: 1.25rem;
	}

	.about-text a {
		border-bottom: 1px solid #1a1a1a;
		transition: opacity 0.2s ease;
	}

	.about-text a:hover {
		opacity: 0.5;
	}

	/* Projects table */
	.mono {
		font-family: 'IBM Plex Mono', monospace;
	}

	.table-header {
		display: grid;
		grid-template-columns: 60px 1fr 1fr 30px;
		gap: 1rem;
		font-size: 0.7rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #999;
		padding-bottom: 0.75rem;
	}

	hr {
		border: none;
		border-top: 1px solid #1a1a1a;
		margin: 0;
	}

	.table-row {
		display: grid;
		grid-template-columns: 60px 1fr 1fr 30px;
		gap: 1rem;
		align-items: baseline;
		padding: 1.25rem 0;
		border-bottom: 1px solid #ddd5cb;
		transition: opacity 0.2s ease;
	}

	.table-row:hover {
		opacity: 0.6;
	}

	.col-no {
		font-size: 0.85rem;
		color: #888;
	}

	.project-name {
		font-size: 1.15rem;
		font-weight: 500;
		font-style: italic;
	}

	.col-detail {
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		color: #666;
	}

	.arrow {
		font-size: 1rem;
		opacity: 0.3;
		transition: opacity 0.2s ease;
		text-align: right;
	}

	.table-row:hover .arrow {
		opacity: 1;
	}

	/* CV */
	h2 {
		font-size: 0.7rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #999;
		margin-bottom: 1.25rem;
	}

	.cv-section {
		margin-bottom: 2rem;
	}

	.entry {
		margin-bottom: 1.5rem;
	}

	.entry-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
	}

	.entry-header strong {
		font-weight: 500;
		font-size: 1.05rem;
	}

	.org {
		font-size: 0.9rem;
		color: #666;
		margin-top: 0.25rem;
		font-style: italic;
	}

	.date {
		font-size: 0.8rem;
		color: #888;
	}

	.placeholder {
		color: #999;
		font-style: italic;
		font-size: 0.9rem;
		margin-top: 1.5rem;
	}

	/* Footer */
	footer {
		margin-top: 6rem;
		padding-top: 1.5rem;
		border-top: 1px solid #ddd5cb;
	}

	footer p {
		font-size: 0.75rem;
		color: #999;
		letter-spacing: 0.08em;
	}

	/* Mobile */
	@media (max-width: 768px) {
		.content-panel {
			width: 100%;
			margin-left: 0;
		}

		#bg-canvas {
			height: 120px;
			position: relative;
			width: 100%;
		}

		.page-wrapper {
			flex-direction: column;
		}

		.panel-body {
			padding: 2rem 1.5rem;
		}

		.tabs {
			padding-left: 1rem;
		}

		.table-header,
		.table-row {
			grid-template-columns: 50px 1fr 30px;
		}

		.col-detail {
			display: none;
		}

		h1 {
			font-size: 2.2rem;
		}
	}
</style>
